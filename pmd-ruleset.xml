<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Règles PMD TPI"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 
         http://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Règles PMD utilisées pour analyser les structures des exercices du module 319.
    </description>

    <!-- Vérifie que les if utilisent bien des accolades -->
    <rule ref="category/java/codestyle.xml/IfStmtsMustUseBraces"/>

    <!-- Vérifie que les boucles for utilisent des accolades -->
    <rule ref="category/java/codestyle.xml/ForLoopsMustUseBraces"/>

    <!-- Vérifie que les switch ont un default -->
    <rule ref="category/java/bestpractices.xml/SwitchStmtsShouldHaveDefault"/>

    <!-- Vérifie qu'il n'y a pas de variables inutilisées -->
    <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>
</ruleset>
